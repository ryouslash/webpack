{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off"
  },
  // 特定の変数がグローバルで存在することをESLintに伝える
  "globals": {
    "jQuery": "readonly", // jQueryをグローバルとして扱う
    "$": "readonly" // $も認識させる
  }
}
